# Resend (transactional email — see lib/email.ts)
# Create / manage keys at https://resend.com/api-keys
RESEND_API_KEY=

# Sender address. Must be on a domain you've verified at
# https://resend.com/domains. Until verified, use:
#   onboarding@resend.dev
# (sandbox — only delivers to addresses on your Resend account).
# Once your domain is verified, switch to e.g.:
#   "Crystal Coat Bookings <bookings@yourdomain.com>"
RESEND_FROM=

# Where booking submissions are emailed. The customer's email is set as
# Reply-To so staff can reply directly.
BOOKING_TO=crystalcoatmobile@gmail.com
BOOKING_CC=lucalatay@gmail.com

# Production base URL — also used for canonical / sitemap / OG / schema.
SITE_URL=http://localhost:3000
